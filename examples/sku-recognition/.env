# SKU Recognition - Environment Variables
# ========================================
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ setup

# ---- Video source (required) ----
# RTSP camera
# SKU_SOURCE=rtsp://192.168.1.100:554/stream
# หรือ local file (ต้อง mount ใน compose.yaml ด้วย)
SKU_SOURCE=/input/conveyor_test.mp4

# ---- Output ----
SKU_HOST_OUTPUT_DIR=./captures

# ---- Detection ----
SKU_PROMPT=product . box . bottle . can . package
SKU_THRESHOLD=0.3

# ---- Line crossing ----
# ชื่อต้องตรงกับ config_nvdsanalytics.txt
SKU_LINE_NAME=SKU_LINE
SKU_COOLDOWN=2.0
SKU_STREAM_NAME=conveyor

# ---- Model selection (เลือกอย่างใดอย่างหนึ่ง) ----
# 1. GroundingDINO — open-vocab ใช้ text prompt (default)
USE_GDINO=true
USE_CUSTOM_MODEL=false

# 2. Custom ONNX/TRT model — ต้องมีไฟล์ model.onnx ใน custom_model/
# USE_GDINO=false
# USE_CUSTOM_MODEL=true
# SKU_CUSTOM_MODEL_CONFIG=/opt/nvidia/sku-recognition/custom_model/nvinfer_config.yaml

# ---- Display ----
# แสดง output window บนจอ (ต้องมี X11 display)
ENABLE_DISPLAY=false
# DISPLAY=:0   ← ถ้า container ไม่เห็น display ให้ set ค่านี้

# ---- GPU ----
# ใส่ GPU index เช่น "0" หรือ "all"
NVIDIA_VISIBLE_DEVICES=all
