# SKU Recognition - Environment Variables
# ========================================
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ setup

# ---- Video source (required) ----
# RTSP camera
# SKU_SOURCE=rtsp://192.168.1.100:554/stream
# หรือ local file (ต้อง mount ใน compose.yaml ด้วย)
SKU_SOURCE=/input/conveyor_test.mp4

# ---- Output ----
SKU_HOST_OUTPUT_DIR=./captures

# ---- Detection ----
SKU_PROMPT=product . box . bottle . can . package
SKU_THRESHOLD=0.3

# ---- Line crossing ----
# ชื่อต้องตรงกับ config_nvdsanalytics.txt
SKU_LINE_NAME=SKU_LINE
SKU_COOLDOWN=2.0
SKU_STREAM_NAME=conveyor

# ---- Model ----
USE_GDINO=true

# ---- GPU ----
# ใส่ GPU index เช่น "0" หรือ "all"
NVIDIA_VISIBLE_DEVICES=0
